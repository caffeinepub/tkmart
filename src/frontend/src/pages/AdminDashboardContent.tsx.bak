import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import {
  Dialog,
  DialogContent,
  DialogFooter,
  DialogHeader,
  DialogTitle,
  DialogTrigger,
} from "@/components/ui/dialog";
import { Input } from "@/components/ui/input";
import { Label } from "@/components/ui/label";
import {
  Select,
  SelectContent,
  SelectItem,
  SelectTrigger,
  SelectValue,
} from "@/components/ui/select";
import { Switch } from "@/components/ui/switch";
import {
  Table,
  TableBody,
  TableCell,
  TableHead,
  TableHeader,
  TableRow,
} from "@/components/ui/table";
import { Tabs, TabsContent, TabsList, TabsTrigger } from "@/components/ui/tabs";
import { Textarea } from "@/components/ui/textarea";
import {
  Bot,
  Circle,
  Crown,
  Loader2,
  LogOut,
  MessageCircle,
  Package,
  Pencil,
  Plus,
  QrCode,
  Send,
  ShoppingCart,
  Tag,
  Trash2,
  Truck,
  Users,
  Video,
} from "lucide-react";
import { useEffect, useRef, useState } from "react";
import { useNavigate } from "react-router-dom";
import { toast } from "sonner";
import { ExternalBlob } from "../backend";
import type {
  AdVideo,
  Category,
  DeliveryAgent,
  Order,
  Product,
} from "../backend.d";
import { OrderStatus } from "../backend.d";
import { useActor } from "../hooks/useActor";
import { clearAdminSession } from "./AdminLoginPage";

// ─── Types ────────────────────────────────────────────────────────────────────

interface ProductForm {
  name: string;
  description: string;
  price: string;
  category: string;
  stock: string;
  imageFile: File | null;
  imageUrl: string;
}

const emptyProductForm = (): ProductForm => ({
  name: "",
  description: "",
  price: "",
  category: "",
  stock: "",
  imageFile: null,
  imageUrl: "",
});

const toSlug = (name: string) =>
  name
    .toLowerCase()
    .trim()
    .replace(/[^a-z0-9\s-]/g, "")
    .replace(/\s+/g, "-");

// ─── Local Category Storage (localStorage-only, no backend) ──────────────────
const LOCAL_CAT_KEY = "tkmart_local_categories";
interface LocalCategory {
  id: number;
  name: string;
  slug: string;
}
function loadLocalCategories(): LocalCategory[] {
  try {
    return JSON.parse(
      localStorage.getItem(LOCAL_CAT_KEY) ?? "[]",
    ) as LocalCategory[];
  } catch {
    return [];
  }
}
function saveLocalCategories(cats: LocalCategory[]) {
  localStorage.setItem(LOCAL_CAT_KEY, JSON.stringify(cats));
}

// ─── Chat Storage ─────────────────────────────────────────────────────────────
const CHAT_KEY = "tkmart_chat_messages";
interface ChatMessage {
  id: string;
  sender: "customer" | "agent";
  text: string;
  timestamp: number;
  customerId: string;
  customerName?: string;
  isAI?: boolean;
}
function loadChatMessages(): ChatMessage[] {
  try {
    return JSON.parse(localStorage.getItem(CHAT_KEY) ?? "[]");
  } catch {
    return [];
  }
}
function saveChatMessages(msgs: ChatMessage[]) {
  localStorage.setItem(CHAT_KEY, JSON.stringify(msgs));
  window.dispatchEvent(new Event("tkmart_chat_updated"));
}

// ─── Payment QR Storage ────────────────────────────────────────────────────
const PAYMENT_QR_KEY = "tkmart_payment_qr";
const PAYMENT_UPI_KEY = "tkmart_payment_upi_id";
function loadPaymentQr(): string {
  return localStorage.getItem(PAYMENT_QR_KEY) ?? "";
}
function savePaymentQr(dataUrl: string) {
  localStorage.setItem(PAYMENT_QR_KEY, dataUrl);
}
function loadPaymentUpiId(): string {
  return localStorage.getItem(PAYMENT_UPI_KEY) ?? "tkmart@upi";
}
function savePaymentUpiId(id: string) {
  localStorage.setItem(PAYMENT_UPI_KEY, id);
}

// ─── Main Component ───────────────────────────────────────────────────────────

export default function AdminDashboardContent() {
  const { actor } = useActor();
  const navigate = useNavigate();

  // ── data state
  const [products, setProducts] = useState<Product[]>([]);
  const [orders, setOrders] = useState<Order[]>([]);
  const [categories, setCategories] = useState<Category[]>([]);
  const [agents, setAgents] = useState<DeliveryAgent[]>([]);
  const [adVideos, setAdVideos] = useState<AdVideo[]>([]);
  const [deliveryChargeInput, setDeliveryChargeInput] = useState<string>(() => {
    const stored = localStorage.getItem("tkmart_delivery_charge");
    return stored ? String(Number.parseInt(stored, 10) / 100) : "0";
  });
  const [paymentQr, setPaymentQr] = useState<string>(() => loadPaymentQr());
  const [paymentUpiId, setPaymentUpiId] = useState<string>(() =>
    loadPaymentUpiId(),
  );
  const paymentQrInputRef = useRef<HTMLInputElement>(null);

  // ── loading
  const [loadingProducts, setLoadingProducts] = useState(false);
  const [loadingOrders, setLoadingOrders] = useState(false);
  const loadingCategories = false;
  const [loadingAgents, setLoadingAgents] = useState(false);
  const [loadingVideos, setLoadingVideos] = useState(false);

  // ── product dialog
  const [productDialogOpen, setProductDialogOpen] = useState(false);
  const [editingProduct, setEditingProduct] = useState<Product | null>(null);
  const [productForm, setProductForm] = useState<ProductForm>(
    emptyProductForm(),
  );
  const [savingProduct, setSavingProduct] = useState(false);
  const imageInputRef = useRef<HTMLInputElement>(null);

  // ── category dialogs
  const [catDialogOpen, setCatDialogOpen] = useState(false);
  const [newCatName, setNewCatName] = useState("");

  const [editCatDialogOpen, setEditCatDialogOpen] = useState(false);
  const [editingCategory, setEditingCategory] = useState<Category | null>(null);
  const [editCatName, setEditCatName] = useState("");

  // ── agent dialog
  const [agentDialogOpen, setAgentDialogOpen] = useState(false);
  const [agentForm, setAgentForm] = useState({ name: "", phone: "" });
  const [savingAgent, setSavingAgent] = useState(false);

  // ── ad video dialog
  const [videoDialogOpen, setVideoDialogOpen] = useState(false);
  const [videoForm, setVideoForm] = useState({ title: "", active: true });
  const [videoFile, setVideoFile] = useState<File | null>(null);
  const [savingVideo, setSavingVideo] = useState(false);
  const videoInputRef = useRef<HTMLInputElement>(null);

  // ── order search
  const [orderPhone, setOrderPhone] = useState("");

  // ── chat state
  const [chatMessages, setChatMessages] = useState<ChatMessage[]>([]);
  const [chatInput, setChatInput] = useState("");
  const chatBottomRef = useRef<HTMLDivElement>(null);
  const [selectedChatId, setSelectedChatId] = useState<string | null>(null);

  // ─── Fetch helpers ─────────────────────────────────────────────────────────

  const fetchProducts = async () => {
    if (!actor) return;
    setLoadingProducts(true);
    try {
      const data = await actor.getAllProducts();
      setProducts(data);
    } catch {
      toast.error("Failed to load products");
    } finally {
      setLoadingProducts(false);
    }
  };

  const fetchCategories = async () => {
    // Load from backend first, fall back to localStorage
    if (actor) {
      try {
        const backendCats = await actor.getCategories();
        if (backendCats.length > 0) {
          // Sync backend categories into localStorage
          const localCats: LocalCategory[] = backendCats.map((c) => ({
            id: Number(c.id),
            name: c.name,
            slug: c.name.toLowerCase().replace(/\s+/g, "-"),
          }));
          saveLocalCategories(localCats);
          setCategories(backendCats);
          return;
        }
      } catch {
        // fall through to localStorage
      }
    }
    setCategories(loadLocalCategories() as unknown as Category[]);
  };

  const fetchAgents = async () => {
    if (!actor) return;
    setLoadingAgents(true);
    try {
      const data = await actor.getDeliveryAgents();
      setAgents(data);
    } catch {
      toast.error("Failed to load delivery agents");
    } finally {
      setLoadingAgents(false);
    }
  };

  const fetchAdVideos = async () => {
    if (!actor) return;
    setLoadingVideos(true);
    try {
      const data = await actor.getAdVideos();
      setAdVideos(data);
    } catch {
      toast.error("Failed to load ad videos");
    } finally {
      setLoadingVideos(false);
    }
  };

  const fetchOrders = async (phone?: string) => {
    if (!actor) return;
    setLoadingOrders(true);
    try {
      const data = phone
        ? await actor.getOrdersByPhone(phone)
        : await actor.getOrdersByPhone("");
      setOrders(data);
    } catch {
      toast.error("Failed to load orders");
    } finally {
      setLoadingOrders(false);
    }
  };

  // biome-ignore lint/correctness/useExhaustiveDependencies: intentional
  useEffect(() => {
    if (!actor) return;
    fetchCategories();
    Promise.all([
      fetchProducts(),
      fetchAgents(),
      fetchAdVideos(),
      fetchOrders(),
    ]);
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [actor]);

  // ─── Logout ─────────────────────────────────────────────────────────────────

  const handleLogout = () => {
    clearAdminSession();
    navigate("/admin-login");
  };

  // ─── Product handlers ──────────────────────────────────────────────────────

  const openNewProduct = () => {
    setEditingProduct(null);
    setProductForm(emptyProductForm());
    setProductDialogOpen(true);
  };

  const openEditProduct = (p: Product) => {
    setEditingProduct(p);
    setProductForm({
      name: p.name,
      description: p.description,
      price: p.price.toString(),
      category:
        categories.find((c) => String(c.id) === String(p.category))?.name ??
        p.category.toString(),
      stock: p.stock.toString(),
      imageFile: null,
      imageUrl: p.image.getDirectURL(),
    });
    setProductDialogOpen(true);
  };

  const handleSaveProduct = async () => {
    if (!actor) return;
    if (!productForm.name || !productForm.price || !productForm.category) {
      toast.error("Name, price and category are required.");
      return;
    }
    setSavingProduct(true);
    try {
      let imageBlob: ExternalBlob;
      if (productForm.imageFile) {
        const buf = await productForm.imageFile.arrayBuffer();
        imageBlob = ExternalBlob.fromBytes(new Uint8Array(buf));
      } else if (editingProduct) {
        imageBlob = editingProduct.image as any;
      } else {
        toast.error("Please select a product image.");
        setSavingProduct(false);
        return;
      }

      const price = BigInt(Math.round(Number(productForm.price)));
      const stock = BigInt(Math.round(Number(productForm.stock) || 0));
      let matchedCat = categories.find(
        (c) =>
          c.name.toLowerCase() === productForm.category.trim().toLowerCase(),
      );
      if (!matchedCat) {
        // Auto-create the category on backend and in localStorage
        try {
          const newBackendId = await actor.createCategory(
            productForm.category.trim(),
          );
          const newLocalCat: LocalCategory = {
            id: Number(newBackendId),
            name: productForm.category.trim(),
            slug: productForm.category
              .trim()
              .toLowerCase()
              .replace(/\s+/g, "-"),
          };
          const updatedCats = [...loadLocalCategories(), newLocalCat];
          saveLocalCategories(updatedCats);
          setCategories(updatedCats as unknown as Category[]);
          matchedCat = newLocalCat as unknown as Category;
        } catch {
          toast.error(
            "Category not found. Please create it first in the Categories tab.",
          );
          setSavingProduct(false);
          return;
        }
      }
      const categoryId = BigInt(matchedCat.id);

      if (editingProduct) {
        await actor.updateProduct(
          editingProduct.id,
          productForm.name,
          productForm.description,
          price,
          categoryId,
          stock,
          imageBlob,
        );
        toast.success("Product updated");
      } else {
        await actor.createProduct(
          productForm.name,
          productForm.description,
          price,
          categoryId,
          stock,
          imageBlob,
        );
        toast.success("Product created");
      }
      setProductDialogOpen(false);
      await fetchProducts();
    } catch (e) {
      toast.error("Failed to save product");
      console.error(e);
    } finally {
      setSavingProduct(false);
    }
  };

  const handleDeleteProduct = async (id: bigint) => {
    if (!actor) return;
    if (!confirm("Delete this product?")) return;
    try {
      await actor.deleteProduct(id);
      toast.success("Product deleted");
      await fetchProducts();
    } catch {
      toast.error("Failed to delete product");
    }
  };

  // ─── Category handlers ────────────────────────────────────────────────────

  const handleCreateCategory = async () => {
    const name = newCatName.trim();
    if (!name) {
      toast.error("Category name is required.");
      return;
    }
    const cats = loadLocalCategories();
    if (cats.some((c) => c.name.toLowerCase() === name.toLowerCase())) {
      toast.error("Category already exists.");
      return;
    }
    let backendId: number = Date.now();
    if (actor) {
      try {
        const id = await actor.createCategory(name);
        backendId = Number(id);
      } catch {
        // backend may reject duplicates; use local id as fallback
      }
    }
    const newCat: LocalCategory = { id: backendId, name, slug: toSlug(name) };
    const updated = [...cats, newCat];
    saveLocalCategories(updated);
    setCategories(updated as unknown as Category[]);
    toast.success("Category created successfully");
    setNewCatName("");
    setCatDialogOpen(false);
  };

  const openEditCategory = (c: Category) => {
    setEditingCategory(c);
    setEditCatName(c.name);
    setEditCatDialogOpen(true);
  };

  const handleUpdateCategory = () => {
    if (!editingCategory) return;
    const name = editCatName.trim();
    if (!name) {
      toast.error("Category name is required.");
      return;
    }
    const cats = loadLocalCategories();
    const idx = cats.findIndex(
      (c) => c.id === (editingCategory.id as unknown as number),
    );
    if (idx >= 0) {
      cats[idx] = { ...cats[idx], name, slug: toSlug(name) };
    } else {
      // Category was from backend - add to local with same id
      cats.push({ id: Date.now(), name, slug: toSlug(name) });
    }
    saveLocalCategories(cats);
    setCategories(cats as unknown as Category[]);
    toast.success("Category updated successfully");
    setEditCatDialogOpen(false);
    setEditingCategory(null);
  };

  const handleDeleteCategory = (id: bigint) => {
    if (!confirm("Delete this category? Products using it may be affected."))
      return;
    const numId = id as unknown as number;
    const cats = loadLocalCategories().filter((c) => c.id !== numId);
    saveLocalCategories(cats);
    setCategories(cats as unknown as Category[]);
    toast.success("Category deleted successfully");
  };

  // ─── Agent handlers ────────────────────────────────────────────────────────

  const handleCreateAgent = async () => {
    if (!actor || !agentForm.name.trim() || !agentForm.phone.trim()) {
      toast.error("Name and phone are required.");
      return;
    }
    setSavingAgent(true);
    try {
      await actor.createDeliveryAgent(
        agentForm.name.trim(),
        agentForm.phone.trim(),
      );
      toast.success("Delivery agent added");
      setAgentForm({ name: "", phone: "" });
      setAgentDialogOpen(false);
      await fetchAgents();
    } catch {
      toast.error("Failed to add agent");
    } finally {
      setSavingAgent(false);
    }
  };

  // ─── Ad video handlers ─────────────────────────────────────────────────────

  const handleAddVideo = async () => {
    if (!actor || !videoForm.title.trim() || !videoFile) {
      toast.error("Title and video file are required.");
      return;
    }
    setSavingVideo(true);
    try {
      const buf = await videoFile.arrayBuffer();
      const blob = ExternalBlob.fromBytes(new Uint8Array(buf));
      await actor.addAdVideo(videoForm.title.trim(), blob, videoForm.active);
      toast.success("Ad video added");
      setVideoForm({ title: "", active: true });
      setVideoFile(null);
      setVideoDialogOpen(false);
      await fetchAdVideos();
    } catch {
      toast.error("Failed to add video");
    } finally {
      setSavingVideo(false);
    }
  };

  // ─── Order handlers ────────────────────────────────────────────────────────

  const handleStatusChange = async (orderId: bigint, status: OrderStatus) => {
    if (!actor) return;
    try {
      await actor.updateOrderStatus(orderId, status);
      toast.success("Order status updated");
      await fetchOrders(orderPhone || undefined);
    } catch {
      toast.error("Failed to update status");
    }
  };

  const handleAssignAgent = async (orderId: bigint, agentId: string) => {
    if (!actor) return;
    try {
      await actor.assignOrderToAgent(orderId, BigInt(agentId));
      toast.success("Agent assigned");
      await fetchOrders(orderPhone || undefined);
    } catch {
      toast.error("Failed to assign agent");
    }
  };

  // ─── Chat handlers ─────────────────────────────────────────────────────────

  const loadChat = () => {
    const msgs = loadChatMessages();
    setChatMessages(msgs);
  };

  // biome-ignore lint/correctness/useExhaustiveDependencies: intentional - loadChat is stable
  useEffect(() => {
    loadChat();
    const handler = () => loadChat();
    window.addEventListener("tkmart_chat_updated", handler);
    const interval = setInterval(() => loadChat(), 2000);
    return () => {
      window.removeEventListener("tkmart_chat_updated", handler);
      clearInterval(interval);
    };
  }, []);

  // biome-ignore lint/correctness/useExhaustiveDependencies: intentional scroll trigger
  useEffect(() => {
    chatBottomRef.current?.scrollIntoView({ behavior: "smooth" });
  }, [chatMessages.length]);

  const chatCustomers = Array.from(
    new Map(chatMessages.map((m) => [m.customerId, m])).values(),
  ).map((m) => ({
    customerId: m.customerId,
    customerName: m.customerName ?? "Customer",
  }));

  const selectedConversation = selectedChatId
    ? chatMessages.filter((m) => m.customerId === selectedChatId)
    : [];

  const sendAgentReply = () => {
    const text = chatInput.trim();
    if (!text || !selectedChatId) return;
    const all = loadChatMessages();
    all.push({
      id: `agent-${Date.now()}-${Math.random()}`,
      sender: "agent",
      text,
      timestamp: Date.now(),
      customerId: selectedChatId,
      customerName: "Support Agent",
    });
    setChatInput("");
    saveChatMessages(all);
    loadChat();
  };

  const getCategoryName = (id: bigint) =>
    categories.find((c) => String(c.id) === String(id))?.name ?? `#${id}`;

  const statusColors: Record<string, string> = {
    pending: "bg-yellow-500/20 text-yellow-400",
    confirmed: "bg-blue-500/20 text-blue-400",
    processing: "bg-purple-500/20 text-purple-400",
    shipped: "bg-cyan-500/20 text-cyan-400",
    outForDelivery: "bg-orange-500/20 text-orange-400",
    delivered: "bg-green-500/20 text-green-400",
    cancelled: "bg-red-500/20 text-red-400",
  };

  // ─── UI ────────────────────────────────────────────────────────────────────

  return (
    <div className="min-h-screen bg-background text-foreground">
      {/* Header */}
      <header className="border-b border-border/50 bg-card/80 backdrop-blur-sm sticky top-0 z-40">
        <div className="max-w-7xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
          <div className="flex items-center gap-3">
            <Crown className="h-6 w-6 text-primary" />
            <span className="font-display text-xl font-bold tracking-wide">
              TKMART <span className="text-primary">Admin</span>
            </span>
          </div>
          <Button
            variant="outline"
            size="sm"
            onClick={handleLogout}
            data-ocid="admin.logout.button"
            className="gap-2"
          >
            <LogOut className="h-4 w-4" />
            Logout
          </Button>
        </div>
      </header>

      <main className="max-w-7xl mx-auto px-4 sm:px-6 py-8">
        <Tabs defaultValue="products" className="space-y-6">
          <TabsList className="grid w-full grid-cols-6 bg-card border border-border/50">
            <TabsTrigger
              value="products"
              className="gap-1.5"
              data-ocid="admin.products.tab"
            >
              <Package className="h-4 w-4" />
              <span className="hidden sm:inline">Products</span>
            </TabsTrigger>
            <TabsTrigger
              value="orders"
              className="gap-1.5"
              data-ocid="admin.orders.tab"
            >
              <ShoppingCart className="h-4 w-4" />
              <span className="hidden sm:inline">Orders</span>
            </TabsTrigger>
            <TabsTrigger
              value="categories"
              className="gap-1.5"
              data-ocid="admin.categories.tab"
            >
              <Tag className="h-4 w-4" />
              <span className="hidden sm:inline">Categories</span>
            </TabsTrigger>
            <TabsTrigger
              value="agents"
              className="gap-1.5"
              data-ocid="admin.agents.tab"
            >
              <Truck className="h-4 w-4" />
              <span className="hidden sm:inline">Delivery</span>
            </TabsTrigger>
            <TabsTrigger
              value="videos"
              className="gap-1.5"
              data-ocid="admin.videos.tab"
            >
              <Video className="h-4 w-4" />
              <span className="hidden sm:inline">Ad Videos</span>
            </TabsTrigger>
            <TabsTrigger
              value="payment"
              className="gap-1.5"
              data-ocid="admin.payment.tab"
            >
              <QrCode className="h-4 w-4" />
              <span className="hidden sm:inline">Payment</span>
            </TabsTrigger>
            <TabsTrigger
              value="chat"
              className="gap-1.5"
              data-ocid="admin.chat.tab"
            >
              <MessageCircle className="h-4 w-4" />
              <span className="hidden sm:inline">Chat</span>
            </TabsTrigger>
          </TabsList>

          {/* ── Products tab ── */}
          <TabsContent value="products" className="space-y-4">
            <div className="flex items-center justify-between">
              <h2 className="text-lg font-semibold">
                Products ({products.length})
              </h2>
              <Button
                onClick={openNewProduct}
                size="sm"
                className="gap-2"
                data-ocid="admin.products.primary_button"
              >
                <Plus className="h-4 w-4" /> Add Product
              </Button>
            </div>

            {loadingProducts ? (
              <div
                className="flex justify-center py-12"
                data-ocid="admin.products.loading_state"
              >
                <Loader2 className="h-8 w-8 animate-spin text-primary" />
              </div>
            ) : products.length === 0 ? (
              <Card data-ocid="admin.products.empty_state">
                <CardContent className="py-12 text-center text-muted-foreground">
                  No products yet. Add your first product.
                </CardContent>
              </Card>
            ) : (
              <Card>
                <Table data-ocid="admin.products.table">
                  <TableHeader>
                    <TableRow>
                      <TableHead>Name</TableHead>
                      <TableHead>Category</TableHead>
                      <TableHead>Price (₹)</TableHead>
                      <TableHead>Stock</TableHead>
                      <TableHead className="text-right">Actions</TableHead>
                    </TableRow>
                  </TableHeader>
                  <TableBody>
                    {products.map((p, i) => (
                      <TableRow
                        key={p.id.toString()}
                        data-ocid={`admin.products.item.${i + 1}`}
                      >
                        <TableCell className="font-medium">{p.name}</TableCell>
                        <TableCell>{getCategoryName(p.category)}</TableCell>
                        <TableCell>₹{p.price.toString()}</TableCell>
                        <TableCell>{p.stock.toString()}</TableCell>
                        <TableCell className="text-right">
                          <div className="flex gap-2 justify-end">
                            <Button
                              variant="ghost"
                              size="icon"
                              onClick={() => openEditProduct(p)}
                              data-ocid={`admin.products.edit_button.${i + 1}`}
                            >
                              <Pencil className="h-4 w-4" />
                            </Button>
                            <Button
                              variant="ghost"
                              size="icon"
                              className="text-destructive hover:text-destructive"
                              onClick={() => handleDeleteProduct(p.id)}
                              data-ocid={`admin.products.delete_button.${i + 1}`}
                            >
                              <Trash2 className="h-4 w-4" />
                            </Button>
                          </div>
                        </TableCell>
                      </TableRow>
                    ))}
                  </TableBody>
                </Table>
              </Card>
            )}

            {/* Product dialog */}
            <Dialog
              open={productDialogOpen}
              onOpenChange={setProductDialogOpen}
            >
              <DialogContent
                className="max-w-lg"
                data-ocid="admin.product.dialog"
              >
                <DialogHeader>
                  <DialogTitle>
                    {editingProduct ? "Edit Product" : "Add Product"}
                  </DialogTitle>
                </DialogHeader>
                <div className="space-y-3">
                  <div>
                    <Label>Name</Label>
                    <Input
                      value={productForm.name}
                      onChange={(e) =>
                        setProductForm((f) => ({ ...f, name: e.target.value }))
                      }
                      placeholder="Product name"
                      data-ocid="admin.product.name.input"
                    />
                  </div>
                  <div>
                    <Label>Description</Label>
                    <Textarea
                      value={productForm.description}
                      onChange={(e) =>
                        setProductForm((f) => ({
                          ...f,
                          description: e.target.value,
                        }))
                      }
                      placeholder="Description"
                      rows={2}
                      data-ocid="admin.product.description.textarea"
                    />
                  </div>
                  <div className="grid grid-cols-2 gap-3">
                    <div>
                      <Label>Price (₹)</Label>
                      <Input
                        type="number"
                        value={productForm.price}
                        onChange={(e) =>
                          setProductForm((f) => ({
                            ...f,
                            price: e.target.value,
                          }))
                        }
                        placeholder="0"
                        data-ocid="admin.product.price.input"
                      />
                    </div>
                    <div>
                      <Label>Stock</Label>
                      <Input
                        type="number"
                        value={productForm.stock}
                        onChange={(e) =>
                          setProductForm((f) => ({
                            ...f,
                            stock: e.target.value,
                          }))
                        }
                        placeholder="0"
                        data-ocid="admin.product.stock.input"
                      />
                    </div>
                  </div>
                  <div>
                    <Label>Category</Label>
                    <Input
                      list="category-suggestions"
                      value={productForm.category}
                      onChange={(e) =>
                        setProductForm((f) => ({
                          ...f,
                          category: e.target.value,
                        }))
                      }
                      placeholder="Type or choose a category"
                      data-ocid="admin.product.category.input"
                    />
                    <datalist id="category-suggestions">
                      {categories.map((c) => (
                        <option key={c.id.toString()} value={c.name} />
                      ))}
                    </datalist>
                  </div>
                  <div>
                    <Label>Image</Label>
                    {productForm.imageUrl && (
                      <img
                        src={productForm.imageUrl}
                        alt="preview"
                        className="h-20 w-20 object-cover rounded mb-2 border border-border"
                      />
                    )}
                    <input
                      ref={imageInputRef}
                      type="file"
                      accept="image/*"
                      className="hidden"
                      onChange={(e) => {
                        const file = e.target.files?.[0];
                        if (file) {
                          setProductForm((f) => ({
                            ...f,
                            imageFile: file,
                            imageUrl: URL.createObjectURL(file),
                          }));
                        }
                      }}
                    />
                    <Button
                      type="button"
                      variant="outline"
                      size="sm"
                      onClick={() => imageInputRef.current?.click()}
                      data-ocid="admin.product.image.upload_button"
                    >
                      {productForm.imageFile ? "Change Image" : "Upload Image"}
                    </Button>
                  </div>
                </div>
                <DialogFooter>
                  <Button
                    variant="outline"
                    onClick={() => setProductDialogOpen(false)}
                    data-ocid="admin.product.cancel_button"
                  >
                    Cancel
                  </Button>
                  <Button
                    onClick={handleSaveProduct}
                    disabled={savingProduct}
                    data-ocid="admin.product.save_button"
                  >
                    {savingProduct ? (
                      <Loader2 className="h-4 w-4 animate-spin mr-2" />
                    ) : null}
                    {editingProduct ? "Update" : "Create"}
                  </Button>
                </DialogFooter>
              </DialogContent>
            </Dialog>
          </TabsContent>

          {/* ── Orders tab ── */}
          <TabsContent value="orders" className="space-y-4">
            {/* Delivery Charge Settings */}
            <Card data-ocid="admin.delivery_charge.card">
              <CardHeader>
                <CardTitle className="text-base flex items-center gap-2">
                  <Truck className="h-4 w-4" />
                  Delivery Charge Settings
                </CardTitle>
              </CardHeader>
              <CardContent>
                <div className="flex items-end gap-3">
                  <div className="flex-1">
                    <Label htmlFor="delivery-charge">Delivery Charge (₹)</Label>
                    <div className="relative mt-1">
                      <span className="absolute left-3 top-1/2 -translate-y-1/2 text-muted-foreground">
                        ₹
                      </span>
                      <Input
                        id="delivery-charge"
                        type="number"
                        min="0"
                        step="1"
                        value={deliveryChargeInput}
                        onChange={(e) => setDeliveryChargeInput(e.target.value)}
                        className="pl-7"
                        placeholder="0"
                        data-ocid="admin.delivery_charge.input"
                      />
                    </div>
                    <p className="text-xs text-muted-foreground mt-1">
                      ₹0 = Free delivery
                    </p>
                  </div>
                  <Button
                    onClick={() => {
                      const val = Math.max(
                        0,
                        Math.round(
                          Number.parseFloat(deliveryChargeInput || "0") * 100,
                        ),
                      );
                      localStorage.setItem(
                        "tkmart_delivery_charge",
                        String(val),
                      );
                      const msg =
                        val === 0
                          ? "Free delivery"
                          : `₹${(val / 100).toFixed(2)}`;
                      toast.success(`Delivery charge set to ${msg}`);
                    }}
                    data-ocid="admin.delivery_charge.save_button"
                  >
                    Save
                  </Button>
                </div>
              </CardContent>
            </Card>

            <div className="flex items-center gap-3">
              <h2 className="text-lg font-semibold">Orders</h2>
              <div className="flex gap-2 ml-auto">
                <Input
                  placeholder="Search by phone…"
                  value={orderPhone}
                  onChange={(e) => setOrderPhone(e.target.value)}
                  className="w-48"
                  data-ocid="admin.orders.search_input"
                />
                <Button
                  size="sm"
                  onClick={() => fetchOrders(orderPhone || undefined)}
                  data-ocid="admin.orders.primary_button"
                >
                  Search
                </Button>
              </div>
            </div>

            {loadingOrders ? (
              <div
                className="flex justify-center py-12"
                data-ocid="admin.orders.loading_state"
              >
                <Loader2 className="h-8 w-8 animate-spin text-primary" />
              </div>
            ) : orders.length === 0 ? (
              <Card data-ocid="admin.orders.empty_state">
                <CardContent className="py-12 text-center text-muted-foreground">
                  No orders found.
                </CardContent>
              </Card>
            ) : (
              <div className="space-y-3" data-ocid="admin.orders.list">
                {orders.map((order, i) => (
                  <Card
                    key={order.id.toString()}
                    data-ocid={`admin.orders.item.${i + 1}`}
                  >
                    <CardContent className="py-4">
                      <div className="flex flex-wrap gap-4 items-start justify-between">
                        <div>
                          <p className="font-medium">{order.customerName}</p>
                          <p className="text-sm text-muted-foreground">
                            {order.customerPhone}
                          </p>
                          <p className="text-sm text-muted-foreground mt-1">
                            {order.address}
                          </p>
                          <p className="text-sm font-semibold mt-1">
                            ₹{order.totalAmount.toString()}
                          </p>
                        </div>
                        <div className="flex flex-col gap-2 min-w-[180px]">
                          <span
                            className={`text-xs px-2 py-0.5 rounded-full font-medium inline-block w-fit ${
                              statusColors[order.status] ?? "bg-muted"
                            }`}
                          >
                            {order.status}
                          </span>
                          <Select
                            value={order.status}
                            onValueChange={(v) =>
                              handleStatusChange(order.id, v as OrderStatus)
                            }
                          >
                            <SelectTrigger
                              className="h-8 text-xs"
                              data-ocid={`admin.orders.status.select.${i + 1}`}
                            >
                              <SelectValue />
                            </SelectTrigger>
                            <SelectContent>
                              {Object.values(OrderStatus).map((s) => (
                                <SelectItem key={s} value={s}>
                                  {s}
                                </SelectItem>
                              ))}
                            </SelectContent>
                          </Select>
                          <Select
                            value={order.deliveryAgent?.toString() ?? ""}
                            onValueChange={(v) =>
                              handleAssignAgent(order.id, v)
                            }
                          >
                            <SelectTrigger
                              className="h-8 text-xs"
                              data-ocid={`admin.orders.agent.select.${i + 1}`}
                            >
                              <SelectValue placeholder="Assign agent" />
                            </SelectTrigger>
                            <SelectContent>
                              {agents.map((a) => (
                                <SelectItem
                                  key={a.id.toString()}
                                  value={a.id.toString()}
                                >
                                  {a.name}
                                </SelectItem>
                              ))}
                            </SelectContent>
                          </Select>
                        </div>
                      </div>
                    </CardContent>
                  </Card>
                ))}
              </div>
            )}
          </TabsContent>

          {/* ── Categories tab ── */}
          <TabsContent value="categories" className="space-y-4">
            <div className="flex items-center justify-between">
              <h2 className="text-lg font-semibold">
                Categories ({categories.length})
              </h2>
              <Dialog open={catDialogOpen} onOpenChange={setCatDialogOpen}>
                <DialogTrigger asChild>
                  <Button
                    size="sm"
                    className="gap-2"
                    data-ocid="admin.categories.primary_button"
                  >
                    <Plus className="h-4 w-4" /> Add Category
                  </Button>
                </DialogTrigger>
                <DialogContent data-ocid="admin.category.dialog">
                  <DialogHeader>
                    <DialogTitle>New Category</DialogTitle>
                  </DialogHeader>
                  <div className="space-y-2">
                    <Label htmlFor="new-cat-name">Category Name</Label>
                    <Input
                      id="new-cat-name"
                      value={newCatName}
                      onChange={(e) => setNewCatName(e.target.value)}
                      onKeyDown={(e) =>
                        e.key === "Enter" && handleCreateCategory()
                      }
                      placeholder="e.g. Electronics"
                      data-ocid="admin.category.name.input"
                    />
                    {newCatName.trim() && (
                      <p className="text-xs text-muted-foreground">
                        Slug:{" "}
                        <span className="font-mono">{toSlug(newCatName)}</span>
                      </p>
                    )}
                  </div>
                  <DialogFooter>
                    <Button
                      variant="outline"
                      onClick={() => {
                        setCatDialogOpen(false);
                        setNewCatName("");
                      }}
                      data-ocid="admin.category.cancel_button"
                    >
                      Cancel
                    </Button>
                    <Button
                      onClick={handleCreateCategory}
                      disabled={!newCatName.trim()}
                      data-ocid="admin.category.save_button"
                    >
                      Create
                    </Button>
                  </DialogFooter>
                </DialogContent>
              </Dialog>
            </div>

            {loadingCategories ? (
              <div
                className="flex justify-center py-12"
                data-ocid="admin.categories.loading_state"
              >
                <Loader2 className="h-8 w-8 animate-spin text-primary" />
              </div>
            ) : categories.length === 0 ? (
              <Card data-ocid="admin.categories.empty_state">
                <CardContent className="py-12 text-center text-muted-foreground">
                  No categories yet. Add your first category.
                </CardContent>
              </Card>
            ) : (
              <div
                className="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3"
                data-ocid="admin.categories.list"
              >
                {categories.map((c, i) => (
                  <Card
                    key={c.id.toString()}
                    data-ocid={`admin.categories.item.${i + 1}`}
                    className="group relative"
                  >
                    <CardContent className="py-4 text-center">
                      <Tag className="h-5 w-5 mx-auto mb-2 text-primary" />
                      <p className="font-medium text-sm">{c.name}</p>
                      <p className="text-xs text-muted-foreground font-mono mt-0.5">
                        {toSlug(c.name)}
                      </p>
                      <div className="flex gap-1 justify-center mt-3">
                        <Button
                          variant="ghost"
                          size="icon"
                          className="h-7 w-7 opacity-70 hover:opacity-100"
                          onClick={() => openEditCategory(c)}
                          data-ocid={`admin.categories.edit_button.${i + 1}`}
                          title="Edit category"
                        >
                          <Pencil className="h-3.5 w-3.5" />
                        </Button>
                        <Button
                          variant="ghost"
                          size="icon"
                          className="h-7 w-7 text-destructive opacity-70 hover:opacity-100 hover:text-destructive"
                          onClick={() => handleDeleteCategory(c.id)}
                          data-ocid={`admin.categories.delete_button.${i + 1}`}
                          title="Delete category"
                        >
                          <Trash2 className="h-3.5 w-3.5" />
                        </Button>
                      </div>
                    </CardContent>
                  </Card>
                ))}
              </div>
            )}

            {/* Edit Category Dialog */}
            <Dialog
              open={editCatDialogOpen}
              onOpenChange={setEditCatDialogOpen}
            >
              <DialogContent data-ocid="admin.category.edit.dialog">
                <DialogHeader>
                  <DialogTitle>Edit Category</DialogTitle>
                </DialogHeader>
                <div className="space-y-2">
                  <Label htmlFor="edit-cat-name">Category Name</Label>
                  <Input
                    id="edit-cat-name"
                    value={editCatName}
                    onChange={(e) => setEditCatName(e.target.value)}
                    onKeyDown={(e) =>
                      e.key === "Enter" && handleUpdateCategory()
                    }
                    placeholder="Category name"
                    data-ocid="admin.category.edit.name.input"
                  />
                  {editCatName.trim() && (
                    <p className="text-xs text-muted-foreground">
                      Slug:{" "}
                      <span className="font-mono">{toSlug(editCatName)}</span>
                    </p>
                  )}
                </div>
                <DialogFooter>
                  <Button
                    variant="outline"
                    onClick={() => setEditCatDialogOpen(false)}
                    data-ocid="admin.category.edit.cancel_button"
                  >
                    Cancel
                  </Button>
                  <Button
                    onClick={handleUpdateCategory}
                    disabled={!editCatName.trim()}
                    data-ocid="admin.category.edit.save_button"
                  >
                    Save Changes
                  </Button>
                </DialogFooter>
              </DialogContent>
            </Dialog>
          </TabsContent>

          {/* ── Delivery Agents tab ── */}
          <TabsContent value="agents" className="space-y-4">
            <div className="flex items-center justify-between">
              <h2 className="text-lg font-semibold">
                Delivery Agents ({agents.length})
              </h2>
              <Dialog open={agentDialogOpen} onOpenChange={setAgentDialogOpen}>
                <DialogTrigger asChild>
                  <Button
                    size="sm"
                    className="gap-2"
                    data-ocid="admin.agents.primary_button"
                  >
                    <Plus className="h-4 w-4" /> Add Agent
                  </Button>
                </DialogTrigger>
                <DialogContent data-ocid="admin.agent.dialog">
                  <DialogHeader>
                    <DialogTitle>New Delivery Agent</DialogTitle>
                  </DialogHeader>
                  <div className="space-y-3">
                    <div>
                      <Label>Name</Label>
                      <Input
                        value={agentForm.name}
                        onChange={(e) =>
                          setAgentForm((f) => ({ ...f, name: e.target.value }))
                        }
                        placeholder="Agent name"
                        data-ocid="admin.agent.name.input"
                      />
                    </div>
                    <div>
                      <Label>Phone</Label>
                      <Input
                        value={agentForm.phone}
                        onChange={(e) =>
                          setAgentForm((f) => ({ ...f, phone: e.target.value }))
                        }
                        placeholder="+91 XXXXX XXXXX"
                        data-ocid="admin.agent.phone.input"
                      />
                    </div>
                  </div>
                  <DialogFooter>
                    <Button
                      variant="outline"
                      onClick={() => setAgentDialogOpen(false)}
                      data-ocid="admin.agent.cancel_button"
                    >
                      Cancel
                    </Button>
                    <Button
                      onClick={handleCreateAgent}
                      disabled={savingAgent}
                      data-ocid="admin.agent.save_button"
                    >
                      {savingAgent ? (
                        <Loader2 className="h-4 w-4 animate-spin mr-2" />
                      ) : null}
                      Add Agent
                    </Button>
                  </DialogFooter>
                </DialogContent>
              </Dialog>
            </div>

            {loadingAgents ? (
              <div
                className="flex justify-center py-12"
                data-ocid="admin.agents.loading_state"
              >
                <Loader2 className="h-8 w-8 animate-spin text-primary" />
              </div>
            ) : agents.length === 0 ? (
              <Card data-ocid="admin.agents.empty_state">
                <CardContent className="py-12 text-center text-muted-foreground">
                  No delivery agents yet.
                </CardContent>
              </Card>
            ) : (
              <Card>
                <Table data-ocid="admin.agents.table">
                  <TableHeader>
                    <TableRow>
                      <TableHead>Name</TableHead>
                      <TableHead>Phone</TableHead>
                      <TableHead>ID</TableHead>
                    </TableRow>
                  </TableHeader>
                  <TableBody>
                    {agents.map((a, i) => (
                      <TableRow
                        key={a.id.toString()}
                        data-ocid={`admin.agents.item.${i + 1}`}
                      >
                        <TableCell className="font-medium">{a.name}</TableCell>
                        <TableCell>{a.phone}</TableCell>
                        <TableCell className="text-muted-foreground text-sm">
                          {a.id.toString()}
                        </TableCell>
                      </TableRow>
                    ))}
                  </TableBody>
                </Table>
              </Card>
            )}
          </TabsContent>

          {/* ── Ad Videos tab ── */}
          <TabsContent value="videos" className="space-y-4">
            <div className="flex items-center justify-between">
              <h2 className="text-lg font-semibold">
                Ad Videos ({adVideos.length})
              </h2>
              <Dialog open={videoDialogOpen} onOpenChange={setVideoDialogOpen}>
                <DialogTrigger asChild>
                  <Button
                    size="sm"
                    className="gap-2"
                    data-ocid="admin.videos.primary_button"
                  >
                    <Plus className="h-4 w-4" /> Add Video
                  </Button>
                </DialogTrigger>
                <DialogContent data-ocid="admin.video.dialog">
                  <DialogHeader>
                    <DialogTitle>New Ad Video</DialogTitle>
                  </DialogHeader>
                  <div className="space-y-3">
                    <div>
                      <Label>Title</Label>
                      <Input
                        value={videoForm.title}
                        onChange={(e) =>
                          setVideoForm((f) => ({ ...f, title: e.target.value }))
                        }
                        placeholder="Video title"
                        data-ocid="admin.video.title.input"
                      />
                    </div>
                    <div>
                      <Label>Video File</Label>
                      <input
                        ref={videoInputRef}
                        type="file"
                        accept="video/*"
                        className="hidden"
                        onChange={(e) =>
                          setVideoFile(e.target.files?.[0] ?? null)
                        }
                      />
                      <div className="flex items-center gap-2">
                        <Button
                          type="button"
                          variant="outline"
                          size="sm"
                          onClick={() => videoInputRef.current?.click()}
                          data-ocid="admin.video.upload_button"
                        >
                          {videoFile ? "Change File" : "Select Video"}
                        </Button>
                        {videoFile && (
                          <span className="text-sm text-muted-foreground">
                            {videoFile.name}
                          </span>
                        )}
                      </div>
                    </div>
                    <div className="flex items-center gap-3">
                      <Label htmlFor="video-active">Active</Label>
                      <Switch
                        id="video-active"
                        checked={videoForm.active}
                        onCheckedChange={(v) =>
                          setVideoForm((f) => ({ ...f, active: v }))
                        }
                        data-ocid="admin.video.active.switch"
                      />
                    </div>
                  </div>
                  <DialogFooter>
                    <Button
                      variant="outline"
                      onClick={() => setVideoDialogOpen(false)}
                      data-ocid="admin.video.cancel_button"
                    >
                      Cancel
                    </Button>
                    <Button
                      onClick={handleAddVideo}
                      disabled={savingVideo}
                      data-ocid="admin.video.save_button"
                    >
                      {savingVideo ? (
                        <Loader2 className="h-4 w-4 animate-spin mr-2" />
                      ) : null}
                      Upload
                    </Button>
                  </DialogFooter>
                </DialogContent>
              </Dialog>
            </div>

            {loadingVideos ? (
              <div
                className="flex justify-center py-12"
                data-ocid="admin.videos.loading_state"
              >
                <Loader2 className="h-8 w-8 animate-spin text-primary" />
              </div>
            ) : adVideos.length === 0 ? (
              <Card data-ocid="admin.videos.empty_state">
                <CardContent className="py-12 text-center text-muted-foreground">
                  No ad videos yet.
                </CardContent>
              </Card>
            ) : (
              <div
                className="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4"
                data-ocid="admin.videos.list"
              >
                {adVideos.map((v, i) => (
                  <Card
                    key={v.id.toString()}
                    data-ocid={`admin.videos.item.${i + 1}`}
                  >
                    <CardHeader className="pb-2">
                      <CardTitle className="text-sm font-medium">
                        {v.title}
                      </CardTitle>
                    </CardHeader>
                    <CardContent>
                      <Badge variant={v.active ? "default" : "secondary"}>
                        {v.active ? "Active" : "Inactive"}
                      </Badge>
                    </CardContent>
                  </Card>
                ))}
              </div>
            )}
          </TabsContent>

          {/* ── Chat tab ── */}
          <TabsContent value="chat" className="space-y-4">
            <h2 className="text-lg font-semibold">Customer Chat</h2>
            {chatMessages.length === 0 ? (
              <Card data-ocid="admin.chat.empty_state">
                <CardContent className="py-12 text-center text-muted-foreground">
                  No customer messages yet.
                </CardContent>
              </Card>
            ) : (
              <div
                className="grid grid-cols-1 md:grid-cols-3 gap-4"
                style={{ height: "480px" }}
              >
                {/* Conversation list */}
                <Card className="overflow-hidden flex flex-col">
                  <CardHeader className="pb-2 px-3 py-3 border-b border-border">
                    <CardTitle className="text-sm flex items-center gap-2">
                      <Users className="h-4 w-4 text-primary" />
                      Conversations ({chatCustomers.length})
                    </CardTitle>
                  </CardHeader>
                  <div
                    className="flex-1 overflow-y-auto"
                    data-ocid="admin.chat.list"
                  >
                    {chatCustomers.map((cust, i) => {
                      const lastMsg = chatMessages
                        .filter((m) => m.customerId === cust.customerId)
                        .slice(-1)[0];
                      return (
                        <button
                          type="button"
                          key={cust.customerId}
                          data-ocid={`admin.chat.item.${i + 1}`}
                          onClick={() => setSelectedChatId(cust.customerId)}
                          className={`w-full text-left px-3 py-3 border-b border-border/50 hover:bg-muted/50 transition-colors ${selectedChatId === cust.customerId ? "bg-primary/10" : ""}`}
                        >
                          <div className="flex items-center gap-2">
                            <div className="h-8 w-8 rounded-full bg-primary/20 flex items-center justify-center text-xs font-bold text-primary flex-shrink-0">
                              {cust.customerName.charAt(0).toUpperCase()}
                            </div>
                            <div className="min-w-0">
                              <p className="text-sm font-medium truncate">
                                {cust.customerName}
                              </p>
                              {lastMsg && (
                                <p className="text-xs text-muted-foreground truncate">
                                  {lastMsg.text}
                                </p>
                              )}
                            </div>
                          </div>
                        </button>
                      );
                    })}
                  </div>
                </Card>

                {/* Conversation view */}
                <Card className="md:col-span-2 flex flex-col overflow-hidden">
                  {!selectedChatId ? (
                    <CardContent className="flex-1 flex items-center justify-center text-muted-foreground text-sm">
                      Select a conversation to reply
                    </CardContent>
                  ) : (
                    <>
                      <CardHeader className="pb-2 px-4 py-3 border-b border-border">
                        <CardTitle className="text-sm">
                          {chatCustomers.find(
                            (c) => c.customerId === selectedChatId,
                          )?.customerName ?? "Customer"}
                        </CardTitle>
                      </CardHeader>
                      <div
                        className="flex-1 overflow-y-auto p-3 space-y-2"
                        data-ocid="admin.chat.panel"
                        style={{ maxHeight: "330px" }}
                      >
                        {selectedConversation.map((m) => (
                          <div
                            key={m.id}
                            className={`flex ${m.sender === "agent" ? "justify-end" : "justify-start"}`}
                          >
                            <div className="max-w-[75%]">
                              {m.isAI && (
                                <div className="flex items-center gap-1 mb-0.5 ml-1">
                                  <Bot className="h-3 w-3 text-teal-400" />
                                  <span className="text-[10px] text-teal-400 font-medium">
                                    TK Assistant (AI)
                                  </span>
                                </div>
                              )}
                              {m.sender === "agent" && !m.isAI && (
                                <div className="flex items-center justify-end mb-0.5 mr-1">
                                  <span className="text-[10px] text-muted-foreground font-medium">
                                    Human Agent
                                  </span>
                                </div>
                              )}
                              <div
                                className={`rounded-2xl px-3 py-2 text-sm ${
                                  m.sender === "agent"
                                    ? m.isAI
                                      ? "bg-teal-500/15 text-foreground border border-teal-500/30 rounded-bl-sm"
                                      : "bg-primary text-primary-foreground rounded-br-sm"
                                    : "bg-muted text-foreground rounded-bl-sm"
                                }`}
                              >
                                <p style={{ whiteSpace: "pre-line" }}>
                                  {m.text}
                                </p>
                                <p
                                  className={`text-[10px] mt-0.5 flex items-center gap-1 ${m.sender === "agent" && !m.isAI ? "text-primary-foreground/60" : "text-muted-foreground"}`}
                                >
                                  {new Date(m.timestamp).toLocaleTimeString(
                                    [],
                                    {
                                      hour: "2-digit",
                                      minute: "2-digit",
                                    },
                                  )}
                                  {m.isAI && (
                                    <span className="bg-teal-500/20 text-teal-400 px-1 rounded text-[9px]">
                                      🤖 AI
                                    </span>
                                  )}
                                </p>
                              </div>
                            </div>
                          </div>
                        ))}
                        <div ref={chatBottomRef} />
                      </div>
                      <div className="flex gap-2 p-3 border-t border-border">
                        <Input
                          data-ocid="admin.chat.input"
                          value={chatInput}
                          onChange={(e) => setChatInput(e.target.value)}
                          onKeyDown={(e) =>
                            e.key === "Enter" && sendAgentReply()
                          }
                          placeholder="Type a reply..."
                          className="flex-1 h-9 text-sm"
                        />
                        <Button
                          data-ocid="admin.chat.submit_button"
                          size="sm"
                          onClick={sendAgentReply}
                          className="h-9 px-3"
                        >
                          <Send className="h-4 w-4" />
                        </Button>
                      </div>
                    </>
                  )}
                </Card>
              </div>
            )}
          </TabsContent>

          {/* ── Payment QR Code tab ── */}
          <TabsContent value="payment" className="space-y-4">
            <Card>
              <CardHeader>
                <CardTitle className="flex items-center gap-2">
                  <QrCode className="h-5 w-5 text-primary" />
                  Payment QR Code &amp; UPI Settings
                </CardTitle>
              </CardHeader>
              <CardContent className="space-y-6">
                <div className="space-y-2">
                  <Label>UPI ID</Label>
                  <div className="flex gap-2">
                    <Input
                      value={paymentUpiId}
                      onChange={(e) => setPaymentUpiId(e.target.value)}
                      placeholder="yourname@upi"
                      data-ocid="admin.payment.upi_id.input"
                    />
                    <Button
                      onClick={() => {
                        savePaymentUpiId(paymentUpiId);
                        toast.success("UPI ID saved");
                      }}
                      data-ocid="admin.payment.upi_id.save_button"
                    >
                      Save
                    </Button>
                  </div>
                  <p className="text-xs text-muted-foreground">
                    This UPI ID will be shown to customers during UPI payment.
                  </p>
                </div>
                <div className="space-y-2">
                  <Label>Payment QR Code Image</Label>
                  <input
                    ref={paymentQrInputRef}
                    type="file"
                    accept="image/*"
                    className="hidden"
                    onChange={(e) => {
                      const file = e.target.files?.[0];
                      if (!file) return;
                      const reader = new FileReader();
                      reader.onload = (ev) => {
                        const dataUrl = ev.target?.result as string;
                        setPaymentQr(dataUrl);
                        savePaymentQr(dataUrl);
                        toast.success("QR code image saved");
                      };
                      reader.readAsDataURL(file);
                    }}
                  />
                  <div className="flex gap-3 items-start">
                    {paymentQr ? (
                      <div className="relative group">
                        <img
                          src={paymentQr}
                          alt="Payment QR Code"
                          className="w-40 h-40 object-contain border rounded-lg bg-white p-2"
                          data-ocid="admin.payment.qr.panel"
                        />
                        <Button
                          variant="destructive"
                          size="sm"
                          className="absolute top-1 right-1 opacity-0 group-hover:opacity-100 transition-opacity h-6 w-6 p-0"
                          onClick={() => {
                            setPaymentQr("");
                            savePaymentQr("");
                            toast.success("QR code removed");
                          }}
                          data-ocid="admin.payment.qr.delete_button"
                        >
                          <Trash2 className="h-3 w-3" />
                        </Button>
                      </div>
                    ) : (
                      <div
                        className="w-40 h-40 border-2 border-dashed border-muted-foreground/30 rounded-lg flex flex-col items-center justify-center gap-2 text-muted-foreground cursor-pointer hover:border-primary/50 transition-colors"
                        onClick={() => paymentQrInputRef.current?.click()}
                        onKeyDown={(e) =>
                          e.key === "Enter" &&
                          paymentQrInputRef.current?.click()
                        }
                        data-ocid="admin.payment.qr.dropzone"
                      >
                        <QrCode className="h-10 w-10" />
                        <span className="text-xs text-center px-2">
                          Click to upload QR code
                        </span>
                      </div>
                    )}
                    <div className="flex-1 space-y-2">
                      <Button
                        variant="outline"
                        onClick={() => paymentQrInputRef.current?.click()}
                        data-ocid="admin.payment.qr.upload_button"
                      >
                        {paymentQr ? "Change QR Image" : "Upload QR Image"}
                      </Button>
                      <p className="text-xs text-muted-foreground">
                        Upload your UPI QR code image. It will be shown to
                        customers when they select UPI payment at checkout.
                      </p>
                    </div>
                  </div>
                </div>
              </CardContent>
            </Card>
          </TabsContent>
        </Tabs>
      </main>
    </div>
  );
}
